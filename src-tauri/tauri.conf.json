{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Ad Creative Studio",
  "version": "0.1.0",
  "identifier": "com.adcreativestudio.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Ad Creative Studio",
        "width": 1240,
        "height": 820,
        "minWidth": 980,
        "minHeight": 700
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": ["**"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all"
  }
}
